<div id="model.nonCSS.idplateEnabled">
  <div class="logo"> <a href="/"><%= siteConfig.siteName %></a> </div>
</div>

<div id="sitetitle">
  <h1 id="metadata.siteTitle.value" class="textColor"></h1>
</div>
<div id="collectionHeader">
  <h1 class="textColor">
  <% collections.forEach(function(col) { %>
    <a style="text-decoration:none;" href="/<%= col.slug %>" id="<%= col.slug %>"><%= col.name %></a>&ensp;
  <% }); %>
  </h1>
</div>

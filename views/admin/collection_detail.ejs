<!DOCTYPE html>
<html>
<head>
    <title><%= __('admin.collectionDetail.manageCollection', { name: collection.name }) %></title>
    <link rel="stylesheet" href="<%= assetUrl('/resources/admin-base.css') %>">
    <link rel="stylesheet" href="<%= assetUrl('/resources/admin-collection-detail.css') %>">
    <meta name="csrf-token" content="<%= csrfToken %>">
</head>
<body>
    <div class="container" id="collection-detail-page" data-collection-id="<%= collection.id %>" data-display-type="<%= collection.display_type || 'single' %>">
        <% const totalMediaCount = media.length; %>
        <% const imageCount = media.filter((m) => !m.isVideo).length; %>
        <% const videoCount = media.filter((m) => !!m.isVideo).length; %>
        <% const reportedCount = media.filter((m) => typeof m.report_markdown === 'string' && m.report_markdown.trim()).length; %>
        <% const unpublishedCount = media.filter((m) => !m.is_published || (m.report_markdown || '') !== (m.published_report_markdown || '')).length; %>
        <% const hasPendingDraftChanges = ((collection.report_markdown || '') !== (collection.published_report_markdown || '') || media.some((m) => !m.is_published || !!m.is_deleted_draft || (m.report_markdown || '') !== (m.published_report_markdown || '') || Number(m.order_index || 0) !== Number(m.published_order_index || 0)) || blocks.some((b) => !b.is_published || !!b.is_deleted_draft || (b.markdown || '') !== (b.published_markdown || '') || (b.media_ids || '[]') !== (b.published_media_ids || '[]') || Number(b.order_index || 0) !== Number(b.published_order_index || 0))); %>
        <div class="page-header">
            <div>
                <a href="/admin" class="btn-link"><%= __('admin.settings.backToDashboard') %></a>
                <h1 style="margin-top: 1rem;"><%= __('admin.collectionDetail.manageCollection', { name: collection.name }) %></h1>
                <p class="page-subtitle"><%= __('admin.collectionDetail.collectionContentManagement') %></p>
            </div>
            <div class="stat-row">
                <span class="stat-pill"><%= __('admin.collectionDetail.totalMedia') %> <strong><%= totalMediaCount %></strong></span>
                <span class="stat-pill"><%= __('admin.collectionDetail.images') %> <strong><%= imageCount %></strong></span>
                <span class="stat-pill"><%= __('admin.collectionDetail.videos') %> <strong><%= videoCount %></strong></span>
                <span class="stat-pill"><%= __('admin.collectionDetail.pendingPublish') %> <strong id="unpublished-count"><%= unpublishedCount %></strong></span>
                <span class="stat-pill"><%= __('admin.collectionDetail.reportedCount') %> <strong id="reported-count"><%= reportedCount %></strong></span>
            </div>
        </div>
        <div id="page-notice" class="page-notice" role="status" aria-live="polite"></div>

        <div id="block-list" class="block-list">
        <% blocks.forEach(function(block) { %>
            <% if (block.block_type === 'media') { %>
                <div class="section block-card block-card-media" data-block-id="<%= block.id %>" data-block-type="media" data-is-published="<%= block.is_published ? '1' : '0' %>" draggable="true">
                    <div class="section-header">
                        <div class="block-card-header-left">
                            <span class="block-handle" title="<%= __('admin.collectionDetail.dragToReorder') %>">⠿</span>
                            <div>
                                <h2><%= __('admin.collectionDetail.mediaManagement') %></h2>
                                <p class="section-subtitle"><%= __('admin.collectionDetail.mediaManagementHint') %></p>
                            </div>
                        </div>
                        <div class="block-card-header-right">
                            <button type="button" class="btn-toggle-collapse" data-block-id="<%= block.id %>" title="<%= __('admin.collectionDetail.collapseBlock') %>">
                                <span class="collapse-icon-open">▾</span><span class="collapse-label-open"><%= __('admin.collectionDetail.collapseBlock') %></span>
                                <span class="collapse-icon-closed">▸</span><span class="collapse-label-closed"><%= __('admin.collectionDetail.expandBlock') %></span>
                            </button>
                            <span class="block-move-group">
                                <button type="button" class="btn-block-move btn-block-up" data-block-id="<%= block.id %>" title="<%= __('admin.collectionDetail.moveUp') %>"><%= __('admin.collectionDetail.moveUp') %></button>
                                <button type="button" class="btn-block-move btn-block-down" data-block-id="<%= block.id %>" title="<%= __('admin.collectionDetail.moveDown') %>"><%= __('admin.collectionDetail.moveDown') %></button>
                            </span>
                            <button type="button" class="btn-delete-block" data-block-id="<%= block.id %>" title="<%= __('admin.collectionDetail.deleteBlock') %>"><%= __('admin.collectionDetail.deleteBlock') %></button>
                        </div>
                    </div>
                    <div class="block-card-body">
                        <div class="panel-soft">
                            <form class="block-upload-form toolbar-row" action="/admin/collections/<%= collection.id %>/media/upload" method="POST" enctype="multipart/form-data" data-block-id="<%= block.id %>">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <input type="hidden" name="block_id" value="<%= block.id %>">
                                <input type="file" name="media" accept="image/*,video/*,.mp4,.mov,.avi,.mkv,.webm,.m4v,.wmv,.flv" multiple required>
                                <button type="submit" class="btn-primary"><%= __('admin.collectionDetail.startUpload') %></button>
                            </form>
                        </div>
                        <div class="block-upload-progress" style="display:none; margin-top: 0.75rem;">
                            <div class="block-upload-progress-text" style="font-size:12px;color:#666;margin-bottom:4px;"><%= __('admin.collectionDetail.preparingUpload') %></div>
                            <div style="height:6px;background:#eee;border-radius:3px;overflow:hidden;">
                                <div class="block-upload-progress-bar" style="width:0%;height:100%;background:#333;"></div>
                            </div>
                        </div>
                        <% const blockMediaIds = JSON.parse(block.media_ids || '[]'); %>
                        <% const blockMediaItems = blockMediaIds.map(mid => media.find(m => m.id === mid)).filter(Boolean); %>
                        <div class="media-grid block-media-grid" data-block-id="<%= block.id %>">
                        <% blockMediaItems.forEach(function(m) { %>
                            <%- include('./partials/collection_detail/media-item', { media: m, collection, csrfToken }) %>
                        <% }); %>
                        </div>
                        <div class="actions-right" style="margin-top: 16px;">
                            <span class="autosave-status block-order-status" data-block-id="<%= block.id %>" aria-live="polite"></span>
                            <button type="button" class="btn-primary btn-save-block-order" data-block-id="<%= block.id %>"><%= __('admin.collectionDetail.saveOrder') %></button>
                        </div>
                    </div>
                </div>
            <% } else { %>
                <div class="section block-card block-card-text" data-block-id="<%= block.id %>" data-block-type="text" data-is-published="<%= block.is_published ? '1' : '0' %>" draggable="true">
                    <div class="section-header">
                        <div class="block-card-header-left">
                            <span class="block-handle" title="<%= __('admin.collectionDetail.dragToReorder') %>">⠿</span>
                            <div>
                                <h2><%= __('admin.collectionDetail.artistStatement') %></h2>
                                <p class="section-subtitle"><%= __('admin.collectionDetail.reportPlaceholder') %></p>
                            </div>
                        </div>
                        <div class="block-card-header-right">
                            <button type="button" class="btn-toggle-collapse" data-block-id="<%= block.id %>" title="<%= __('admin.collectionDetail.collapseBlock') %>">
                                <span class="collapse-icon-open">▾</span><span class="collapse-label-open"><%= __('admin.collectionDetail.collapseBlock') %></span>
                                <span class="collapse-icon-closed">▸</span><span class="collapse-label-closed"><%= __('admin.collectionDetail.expandBlock') %></span>
                            </button>
                            <span class="block-move-group">
                                <button type="button" class="btn-block-move btn-block-up" data-block-id="<%= block.id %>" title="<%= __('admin.collectionDetail.moveUp') %>"><%= __('admin.collectionDetail.moveUp') %></button>
                                <button type="button" class="btn-block-move btn-block-down" data-block-id="<%= block.id %>" title="<%= __('admin.collectionDetail.moveDown') %>"><%= __('admin.collectionDetail.moveDown') %></button>
                            </span>
                            <button type="button" class="btn-delete-block" data-block-id="<%= block.id %>" title="<%= __('admin.collectionDetail.deleteBlock') %>"><%= __('admin.collectionDetail.deleteBlock') %></button>
                        </div>
                    </div>
                    <div class="block-card-body">
                        <div class="block-text-editor">
                            <textarea name="markdown" placeholder="<%= __('admin.collectionDetail.reportPlaceholder') %>"><%= block.markdown || '' %></textarea>
                            <div class="block-text-actions">
                                <button type="button" class="btn-primary btn-save-text-block" data-block-id="<%= block.id %>"><%= __('admin.collectionDetail.saveText') %></button>
                                <span class="autosave-status" data-role="block-save-status"></span>
                            </div>
                        </div>
                    </div>
                </div>
            <% } %>
        <% }); %>
        </div>

        <div class="block-add-bar">
            <button type="button" id="add-text-block" class="btn-add-block"><%= __('admin.collectionDetail.addTextBlock') %></button>
            <button type="button" id="add-media-block" class="btn-add-block"><%= __('admin.collectionDetail.addMediaBlock') %></button>
        </div>

        <%- include('./partials/collection_detail/draft-panel', { hasPendingDraftChanges }) %>
    </div>

    <script>window.__i18n = <%- JSON.stringify(__catalog) %>;</script>
    <script src="<%= assetUrl('/resources/js/admin-collection-detail.js') %>"></script>
    <script src="<%= assetUrl('/resources/js/admin-block-editor.js') %>"></script>
</body>
</html>

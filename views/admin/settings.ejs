<!DOCTYPE html>
<html>
<head>
    <title><%= __('admin.settings.title') %> - Admin</title>
    <link rel="stylesheet" href="<%= assetUrl('/resources/admin-base.css') %>">
    <link rel="stylesheet" href="<%= assetUrl('/resources/admin-settings.css') %>">
    <meta name="csrf-token" content="<%= csrfToken %>">
</head>
<body>
    <div class="container">
        <div class="page-header">
            <div>
                <a href="/admin" class="btn-link"><%= __('admin.settings.backToDashboard') %></a>
                <h1 style="margin-top: 1rem;"><%= __('admin.settings.title') %></h1>
                <p class="page-subtitle"><%= __('admin.settings.subtitle') %></p>
            </div>
        </div>

        <% if (locals.success) { %>
            <div class="notice notice-success"><%= success %></div>
        <% } %>
        <% if (locals.error) { %>
            <div class="notice notice-error"><%= error %></div>
        <% } %>

        <form action="/admin/settings" method="POST" id="settings-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

            <div class="settings-section">
                <h2 class="section-title"><%= __('admin.settings.basicInfo') %></h2>
                <div class="field-group">
                    <label for="siteName"><%= __('admin.settings.siteName') %></label>
                    <p class="field-hint"><%= __('admin.settings.siteNameHint') %></p>
                    <input type="text" id="siteName" name="siteName" value="<%= config.siteName %>" placeholder="Art Space">
                </div>
                <div class="field-group">
                    <label for="siteTitle"><%= __('admin.settings.siteTitle') %></label>
                    <p class="field-hint"><%= __('admin.settings.siteTitleHint') %></p>
                    <input type="text" id="siteTitle" name="siteTitle" value="<%= config.siteTitle %>" placeholder="Art Space — Works">
                </div>
            </div>

            <div class="settings-section">
                <h2 class="section-title"><%= __('admin.settings.signatureAndFiling') %></h2>
                <div class="field-group">
                    <label for="fullSignature"><%= __('admin.settings.fullSignature') %></label>
                    <p class="field-hint"><%= __('admin.settings.fullSignatureHint') %></p>
                    <input type="text" id="fullSignature" name="fullSignature" value="<%= config.fullSignature %>" placeholder="Art by Artist Name">
                </div>
                <div class="field-group">
                    <label for="shortSignature"><%= __('admin.settings.shortSignature') %></label>
                    <p class="field-hint"><%= __('admin.settings.shortSignatureHint') %></p>
                    <input type="text" id="shortSignature" name="shortSignature" value="<%= config.shortSignature %>" placeholder="Art by Artist Name">
                </div>
                <div class="field-group">
                    <label for="icpNumber"><%= __('admin.settings.icpNumber') %></label>
                    <p class="field-hint"><%= __('admin.settings.icpNumberHint') %></p>
                    <input type="text" id="icpNumber" name="icpNumber" value="<%= config.icpNumber %>" placeholder="某ICP备xxxxxx号">
                </div>
                <div class="field-group">
                    <label for="icpLink"><%= __('admin.settings.icpLink') %></label>
                    <p class="field-hint"><%= __('admin.settings.icpLinkHint') %></p>
                    <input type="text" id="icpLink" name="icpLink" value="<%= config.icpLink %>" placeholder="https://beian.miit.gov.cn/">
                </div>
            </div>

            <div class="settings-section">
                <h2 class="section-title"><%= __('admin.settings.socialLinks') %></h2>
                <p class="section-hint"><%= __('admin.settings.socialLinksHint') %></p>
                <div id="social-links-container">
                    <% config.socialLinks.forEach(function(link, i) { %>
                        <div class="social-link-row" data-index="<%= i %>">
                            <input type="text" name="socialLabel_<%= i %>" value="<%= link.label %>" placeholder="<%= __('admin.settings.labelPlaceholder') %>" class="social-label">
                            <input type="text" name="socialUrl_<%= i %>" value="<%= link.url %>" placeholder="<%= __('admin.settings.urlPlaceholder') %>" class="social-url">
                            <button type="button" class="btn-remove-social btn-link" title="<%= __('admin.collectionCard.delete') %>">✕</button>
                        </div>
                    <% }); %>
                </div>
                <button type="button" id="add-social-btn" class="btn-link"><%= __('admin.settings.addLink') %></button>
            </div>

            <div class="settings-section">
                <h2 class="section-title"><%= __('admin.settings.mediaConfig') %></h2>
                <p class="section-hint"><%= __('admin.settings.mediaConfigHint') %></p>

                <h3 class="subsection-title"><%= __('admin.settings.imageVariantWidths') %></h3>
                <div class="field-group">
                    <label for="imageVariantWidthThumb"><%= __('admin.settings.thumbMaxWidth') %></label>
                    <select id="imageVariantWidthThumb" name="imageVariantWidthThumb">
                        <option value="300" <%= config.imageVariantWidthThumb === 300 ? 'selected' : '' %>>300px</option>
                        <option value="400" <%= config.imageVariantWidthThumb === 400 ? 'selected' : '' %>>400px</option>
                        <option value="600" <%= config.imageVariantWidthThumb === 600 ? 'selected' : '' %>>600px</option>
                        <option value="800" <%= config.imageVariantWidthThumb === 800 ? 'selected' : '' %>>800px</option>
                    </select>
                </div>
                <div class="field-group">
                    <label for="imageVariantWidthMedium"><%= __('admin.settings.mediumMaxWidth') %></label>
                    <select id="imageVariantWidthMedium" name="imageVariantWidthMedium">
                        <option value="800" <%= config.imageVariantWidthMedium === 800 ? 'selected' : '' %>>800px</option>
                        <option value="1000" <%= config.imageVariantWidthMedium === 1000 ? 'selected' : '' %>>1000px</option>
                        <option value="1200" <%= config.imageVariantWidthMedium === 1200 ? 'selected' : '' %>>1200px</option>
                        <option value="1400" <%= config.imageVariantWidthMedium === 1400 ? 'selected' : '' %>>1400px</option>
                        <option value="1600" <%= config.imageVariantWidthMedium === 1600 ? 'selected' : '' %>>1600px</option>
                    </select>
                </div>
                <div class="field-group">
                    <label for="imageVariantWidthLarge"><%= __('admin.settings.largeMaxWidth') %></label>
                    <select id="imageVariantWidthLarge" name="imageVariantWidthLarge">
                        <option value="1600" <%= config.imageVariantWidthLarge === 1600 ? 'selected' : '' %>>1600px</option>
                        <option value="2000" <%= config.imageVariantWidthLarge === 2000 ? 'selected' : '' %>>2000px</option>
                        <option value="2400" <%= config.imageVariantWidthLarge === 2400 ? 'selected' : '' %>>2400px</option>
                        <option value="2800" <%= config.imageVariantWidthLarge === 2800 ? 'selected' : '' %>>2800px</option>
                        <option value="3200" <%= config.imageVariantWidthLarge === 3200 ? 'selected' : '' %>>3200px</option>
                    </select>
                </div>

                <h3 class="subsection-title"><%= __('admin.settings.imageCompressionQuality') %></h3>
                <div class="field-group">
                    <label for="imageVariantQuality"><%= __('admin.settings.variantImageQuality') %></label>
                    <select id="imageVariantQuality" name="imageVariantQuality">
                        <option value="60" <%= config.imageVariantQuality === 60 ? 'selected' : '' %>>60（<%= __('admin.settings.highCompression') %>）</option>
                        <option value="70" <%= config.imageVariantQuality === 70 ? 'selected' : '' %>>70</option>
                        <option value="75" <%= config.imageVariantQuality === 75 ? 'selected' : '' %>>75</option>
                        <option value="80" <%= config.imageVariantQuality === 80 ? 'selected' : '' %>>80</option>
                        <option value="82" <%= config.imageVariantQuality === 82 ? 'selected' : '' %>>82（<%= __('admin.settings.recommended') %>）</option>
                        <option value="85" <%= config.imageVariantQuality === 85 ? 'selected' : '' %>>85</option>
                        <option value="90" <%= config.imageVariantQuality === 90 ? 'selected' : '' %>>90（<%= __('admin.settings.lowCompression') %>）</option>
                    </select>
                </div>
                <div class="field-group">
                    <label for="imageOriginalQuality"><%= __('admin.settings.originalImageQuality') %></label>
                    <select id="imageOriginalQuality" name="imageOriginalQuality">
                        <option value="80" <%= config.imageOriginalQuality === 80 ? 'selected' : '' %>>80</option>
                        <option value="85" <%= config.imageOriginalQuality === 85 ? 'selected' : '' %>>85</option>
                        <option value="90" <%= config.imageOriginalQuality === 90 ? 'selected' : '' %>>90（<%= __('admin.settings.recommended') %>）</option>
                        <option value="95" <%= config.imageOriginalQuality === 95 ? 'selected' : '' %>>95</option>
                        <option value="100" <%= config.imageOriginalQuality === 100 ? 'selected' : '' %>>100（<%= __('admin.settings.lossless') %>）</option>
                    </select>
                </div>

                <h3 class="subsection-title"><%= __('admin.settings.videoEncodingParams') %></h3>
                <div class="field-group">
                    <label for="videoCrf"><%= __('admin.settings.videoCrf') %></label>
                    <p class="field-hint"><%= __('admin.settings.videoCrfHint') %></p>
                    <select id="videoCrf" name="videoCrf">
                        <option value="18" <%= config.videoCrf === 18 ? 'selected' : '' %>>18（<%= __('admin.settings.highQuality') %>）</option>
                        <option value="20" <%= config.videoCrf === 20 ? 'selected' : '' %>>20</option>
                        <option value="23" <%= config.videoCrf === 23 ? 'selected' : '' %>>23（<%= __('admin.settings.recommended') %>）</option>
                        <option value="26" <%= config.videoCrf === 26 ? 'selected' : '' %>>26</option>
                        <option value="28" <%= config.videoCrf === 28 ? 'selected' : '' %>>28（<%= __('admin.settings.highCompression') %>）</option>
                        <option value="30" <%= config.videoCrf === 30 ? 'selected' : '' %>>30</option>
                    </select>
                </div>
                <div class="field-group">
                    <label for="videoBitrate"><%= __('admin.settings.videoBitrate') %></label>
                    <select id="videoBitrate" name="videoBitrate">
                        <option value="1000k" <%= config.videoBitrate === '1000k' ? 'selected' : '' %>>1000k</option>
                        <option value="1500k" <%= config.videoBitrate === '1500k' ? 'selected' : '' %>>1500k</option>
                        <option value="2000k" <%= config.videoBitrate === '2000k' ? 'selected' : '' %>>2000k（<%= __('admin.settings.recommended') %>）</option>
                        <option value="3000k" <%= config.videoBitrate === '3000k' ? 'selected' : '' %>>3000k</option>
                        <option value="5000k" <%= config.videoBitrate === '5000k' ? 'selected' : '' %>>5000k</option>
                        <option value="8000k" <%= config.videoBitrate === '8000k' ? 'selected' : '' %>>8000k</option>
                    </select>
                </div>
                <div class="field-group">
                    <label for="videoMaxResolution"><%= __('admin.settings.videoMaxResolution') %></label>
                    <select id="videoMaxResolution" name="videoMaxResolution">
                        <option value="1280x720" <%= config.videoMaxResolution === '1280x720' ? 'selected' : '' %>>720p (1280×720)</option>
                        <option value="1920x1080" <%= config.videoMaxResolution === '1920x1080' ? 'selected' : '' %>>1080p (1920×1080)（<%= __('admin.settings.recommended') %>）</option>
                        <option value="2560x1440" <%= config.videoMaxResolution === '2560x1440' ? 'selected' : '' %>>1440p (2560×1440)</option>
                        <option value="3840x2160" <%= config.videoMaxResolution === '3840x2160' ? 'selected' : '' %>>4K (3840×2160)</option>
                    </select>
                </div>
                <div class="field-group">
                    <label for="videoPreset"><%= __('admin.settings.videoPreset') %></label>
                    <p class="field-hint"><%= __('admin.settings.videoPresetHint') %></p>
                    <select id="videoPreset" name="videoPreset">
                        <option value="ultrafast" <%= config.videoPreset === 'ultrafast' ? 'selected' : '' %>>ultrafast（<%= __('admin.settings.fastestEncoding') %>）</option>
                        <option value="veryfast" <%= config.videoPreset === 'veryfast' ? 'selected' : '' %>>veryfast</option>
                        <option value="fast" <%= config.videoPreset === 'fast' ? 'selected' : '' %>>fast</option>
                        <option value="medium" <%= config.videoPreset === 'medium' ? 'selected' : '' %>>medium</option>
                        <option value="slow" <%= config.videoPreset === 'slow' ? 'selected' : '' %>>slow（<%= __('admin.settings.recommended') %>）</option>
                        <option value="slower" <%= config.videoPreset === 'slower' ? 'selected' : '' %>>slower</option>
                        <option value="veryslow" <%= config.videoPreset === 'veryslow' ? 'selected' : '' %>>veryslow（<%= __('admin.settings.maxCompression') %>）</option>
                    </select>
                </div>
            </div>

            <div class="settings-section">
                <h2 class="section-title"><%= __('admin.settings.languageSection') %></h2>
                <p class="section-hint"><%= __('admin.settings.languageHint') %></p>
                <div class="field-group">
                    <label for="language"><%= __('admin.settings.language') %></label>
                    <select id="language" name="language">
                        <option value="" <%= (!config.language) ? 'selected' : '' %>><%= __('admin.settings.languageAuto') %></option>
                        <option value="zh-CN" <%= config.language === 'zh-CN' ? 'selected' : '' %>>中文简体</option>
                        <option value="zh-TW" <%= config.language === 'zh-TW' ? 'selected' : '' %>>中文繁体</option>
                        <option value="ja" <%= config.language === 'ja' ? 'selected' : '' %>>日本語</option>
                        <option value="en" <%= config.language === 'en' ? 'selected' : '' %>>English</option>
                    </select>
                </div>
            </div>

            <div class="settings-section">
                <h2 class="section-title"><%= __('admin.settings.about') %></h2>
                <div class="about-columns">
                    <div class="about-column">
                        <h3 class="subsection-title"><%= __('admin.settings.aboutSystemInfo') %></h3>
                        <div class="about-info-grid">
                            <span class="about-info-label"><%= __('admin.settings.aboutProjectName') %></span>
                            <span class="about-info-value"><a href="https://github.com/Rinux119/art-media-publishing-site" target="_blank" rel="noopener noreferrer">Art Media Publishing Site</a></span>
                            <span class="about-info-label"><%= __('admin.settings.aboutVersion') %></span>
                            <span class="about-info-value">v<%= version %></span>
                            <span class="about-info-label"><%= __('admin.settings.aboutCreator') %></span>
                            <span class="about-info-value"><a href="https://jhentsanyan.art" target="_blank" rel="noopener noreferrer">Jhen Tsan-Yan</a></span>
                            <span class="about-info-label"><%= __('admin.settings.aboutLicense') %></span>
                            <span class="about-info-value"><%= license %></span>
                        </div>
                    </div>
                    <div class="about-column">
                        <h3 class="subsection-title"><%= __('admin.settings.aboutRuntime') %></h3>
                        <div class="about-info-grid">
                            <span class="about-info-label"><%= __('admin.settings.aboutNodeVersion') %></span>
                            <span class="about-info-value"><%= runtimeInfo.nodeVersion %></span>
                            <span class="about-info-label"><%= __('admin.settings.aboutDatabase') %></span>
                            <span class="about-info-value"><%= runtimeInfo.sqliteVersion || __('admin.settings.aboutNotDetected') %></span>
                            <span class="about-info-label"><%= __('admin.settings.aboutImageProcessor') %></span>
                            <span class="about-info-value"><%= runtimeInfo.sharpVersion || __('admin.settings.aboutNotDetected') %></span>
                            <span class="about-info-label"><%= __('admin.settings.aboutVideoTranscoder') %></span>
                            <span class="about-info-value"><%= runtimeInfo.ffmpegVersion || __('admin.settings.aboutNotDetected') %></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary"><%= __('admin.settings.saveSettings') %></button>
            </div>
        </form>
    </div>

    <script>
    (function() {
        function showNotice(type, message) {
            var existing = document.querySelectorAll('.notice-ajax');
            existing.forEach(function(n) { n.remove(); });
            var header = document.querySelector('.page-header');
            if (!header) return;
            var div = document.createElement('div');
            div.className = 'notice notice-' + type + ' notice-ajax';
            div.textContent = message;
            header.parentNode.insertBefore(div, header.nextSibling);
            setTimeout(function() { div.remove(); }, 5000);
        }

        function initSettingsPage() {
            var form = document.getElementById('settings-form');
            if (!form) return;

            form.dataset.originalLanguage = (document.getElementById('language') || {}).value || '';

            form.addEventListener('submit', function(e) {
                e.preventDefault();
                var params = new URLSearchParams();
                var inputs = form.querySelectorAll('input, select, textarea');
                inputs.forEach(function(el) {
                    if (!el.name || el.type === 'file') return;
                    if (el.type === 'checkbox' && !el.checked) return;
                    params.append(el.name, el.value);
                });
                var langSelect = document.getElementById('language');
                var languageChanged = langSelect && langSelect.value !== (form.dataset.originalLanguage || '');
                var submitBtn = form.querySelector('.btn-primary');
                var originalText = submitBtn.textContent;
                submitBtn.disabled = true;
                submitBtn.textContent = '...';

                fetch(form.action, {
                    method: 'POST',
                    headers: { 'Accept': 'application/json', 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: params.toString()
                })
                .then(function(res) { return res.json(); })
                .then(function(data) {
                    submitBtn.disabled = false;
                    submitBtn.textContent = originalText;
                    if (data.success) {
                        if (languageChanged) {
                            fetch(window.location.href, { credentials: 'same-origin' })
                                .then(function(r) { return r.text(); })
                                .then(function(html) {
                                    var parser = new DOMParser();
                                    var doc = parser.parseFromString(html, 'text/html');
                                    document.querySelector('.container').innerHTML = doc.querySelector('.container').innerHTML;
                                    initSettingsPage();
                                    showNotice('success', data.message);
                                });
                        } else {
                            showNotice('success', data.message);
                        }
                    } else {
                        showNotice('error', data.error);
                    }
                })
                .catch(function(err) {
                    submitBtn.disabled = false;
                    submitBtn.textContent = originalText;
                    showNotice('error', err.message);
                });
            });

            var container = document.getElementById('social-links-container');
            var addBtn = document.getElementById('add-social-btn');
            if (!container || !addBtn) return;

            function getNextIndex() {
                var rows = container.querySelectorAll('.social-link-row');
                var max = -1;
                rows.forEach(function(row) {
                    var idx = parseInt(row.getAttribute('data-index'), 10);
                    if (idx > max) max = idx;
                });
                return max + 1;
            }

            addBtn.addEventListener('click', function() {
                var idx = getNextIndex();
                var div = document.createElement('div');
                div.className = 'social-link-row';
                div.setAttribute('data-index', idx);
                div.innerHTML =
                    '<input type="text" name="socialLabel_' + idx + '" value="" placeholder="' + <%- JSON.stringify(__('admin.settings.labelPlaceholder')) %> + '" class="social-label">' +
                    '<input type="text" name="socialUrl_' + idx + '" value="" placeholder="' + <%- JSON.stringify(__('admin.settings.urlPlaceholder')) %> + '" class="social-url">' +
                    '<button type="button" class="btn-remove-social btn-link" title="✕">✕</button>';
                container.appendChild(div);
            });

            container.addEventListener('click', function(e) {
                if (e.target.classList.contains('btn-remove-social')) {
                    var row = e.target.closest('.social-link-row');
                    if (row) row.remove();
                }
            });
        }

        initSettingsPage();
    })();
    </script>
</body>
</html>

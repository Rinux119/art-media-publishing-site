<!DOCTYPE html>
<html>
<head>
    <title><%= __('admin.users.title') %> - Admin</title>
    <link rel="stylesheet" href="<%= assetUrl('/resources/admin-base.css') %>">
    <link rel="stylesheet" href="<%= assetUrl('/resources/admin-users.css') %>">
    <meta name="csrf-token" content="<%= csrfToken %>">
</head>
<body>
    <div class="container">
        <div class="page-header">
            <div>
                <a href="/admin" class="btn-link"><%= __('admin.settings.backToDashboard') %></a>
                <h1 style="margin-top: 1rem;"><%= __('admin.users.title') %></h1>
                <p class="page-subtitle"><%= __('admin.users.subtitle') %></p>
            </div>
        </div>

        <div id="notice" class="notice" style="display:none;"></div>

        <div class="section-header">
            <h2><%= __('admin.users.userList') %></h2>
            <button type="button" id="add-user-btn" class="btn-primary"><%= __('admin.users.addUser') %></button>
        </div>

        <table class="user-table">
            <thead>
                <tr>
                    <th><%= __('admin.users.id') %></th>
                    <th><%= __('admin.users.username') %></th>
                    <th><%= __('admin.users.keyStatus') %></th>
                    <th><%= __('admin.users.actions') %></th>
                </tr>
            </thead>
            <tbody id="user-table-body">
            </tbody>
        </table>
    </div>

    <div id="modal-overlay" class="modal-overlay" style="display:none;">
        <div id="modal-box" class="modal-box">
            <div class="modal-header">
                <h3 id="modal-title"></h3>
                <button type="button" class="modal-close-btn" id="modal-close">&times;</button>
            </div>
            <div id="modal-body" class="modal-body"></div>
        </div>
    </div>

    <script>
    (function() {
        var i18n = {
            loadFailed: <%- JSON.stringify(__('admin.users.loadFailed')) %>,
            requestFailed: <%- JSON.stringify(__('admin.users.requestFailed')) %>,
            keyConfigured: <%- JSON.stringify(__('admin.users.configured')) %>,
            keyNotConfigured: <%- JSON.stringify(__('admin.users.notConfigured')) %>,
            defaultBadge: <%- JSON.stringify(__('admin.users.default')) %>,
            changePassword: <%- JSON.stringify(__('admin.users.changePassword')) %>,
            clearKey: <%- JSON.stringify(__('admin.users.clearKey')) %>,
            generateKey: <%- JSON.stringify(__('admin.users.generateKey')) %>,
            deleteBtn: <%- JSON.stringify(__('admin.users.delete')) %>,
            oldPassword: <%- JSON.stringify(__('admin.users.oldPassword')) %>,
            newPassword: <%- JSON.stringify(__('admin.users.newPassword')) %>,
            confirmPassword: <%- JSON.stringify(__('admin.users.confirmPassword')) %>,
            confirmChange: <%- JSON.stringify(__('admin.users.confirmChange')) %>,
            cancel: <%- JSON.stringify(__('admin.users.cancel')) %>,
            keyLabel: <%- JSON.stringify(__('admin.users.key')) %>,
            confirmKey: <%- JSON.stringify(__('admin.users.confirmKey')) %>,
            confirmKeyAgain: <%- JSON.stringify(__('admin.users.confirmKeyAgain')) %>,
            generateKeyBtn: <%- JSON.stringify(__('admin.users.generateKeyButton')) %>,
            keyGenHint: <%- JSON.stringify(__('admin.users.generateKeyHint')) %>,
            clearKeyConfirm: <%- JSON.stringify(__('admin.users.confirmClearKey')) %>,
            keyCleared: <%- JSON.stringify(__('admin.users.keyCleared')) %>,
            clearFailed: <%- JSON.stringify(__('admin.users.clearFailed')) %>,
            deleteUserConfirm: <%- JSON.stringify(__('admin.users.confirmDeleteUser')) %>,
            userDeleted: <%- JSON.stringify(__('admin.users.userDeleted')) %>,
            deleteFailed: <%- JSON.stringify(__('admin.users.deleteFailed')) %>,
            addNewUser: <%- JSON.stringify(__('admin.users.addNewUser')) %>,
            usernameLabel: <%- JSON.stringify(__('admin.users.username')) %>,
            passwordLabel: <%- JSON.stringify(__('admin.users.password')) %>,
            confirmPasswordLabel: <%- JSON.stringify(__('admin.users.confirmPassword')) %>,
            createUser: <%- JSON.stringify(__('admin.users.createUser')) %>,
            passwordMismatch: <%- JSON.stringify(__('admin.users.passwordMismatch')) %>,
            passwordChangeSuccess: <%- JSON.stringify(__('admin.users.passwordChanged')) %>,
            changeFailed: <%- JSON.stringify(__('admin.users.changeFailed')) %>,
            keyMismatch: <%- JSON.stringify(__('admin.users.keyMismatch')) %>,
            keyGenConfirm: <%- JSON.stringify(__('admin.users.confirmGenerateKey')) %>,
            keyGenSuccess: <%- JSON.stringify(__('admin.users.keyGenerated')) %>,
            keyGenFailed: <%- JSON.stringify(__('admin.users.generateFailed')) %>,
            keyRevealHint: <%- JSON.stringify(__('admin.users.keyGenerated')) %>,
            showKey: <%- JSON.stringify(__('admin.users.show')) %>,
            confirmAndClose: <%- JSON.stringify(__('admin.users.confirmAndClose')) %>,
            userCreated: <%- JSON.stringify(__('admin.users.userCreated')) %>,
            createFailed: <%- JSON.stringify(__('admin.users.createFailed')) %>,
            changePasswordTitle: <%- JSON.stringify(__('admin.users.changePasswordTitle')) %>,
            generateKeyTitle: <%- JSON.stringify(__('admin.users.generateKeyTitle')) %>
        };

        function getCsrfToken() {
            return document.querySelector('meta[name="csrf-token"]').getAttribute('content');
        }

        function showNotice(text, type) {
            var el = document.getElementById('notice');
            el.textContent = text;
            el.className = 'notice ' + (type === 'error' ? 'notice-error' : 'notice-success');
            el.style.display = 'block';
            setTimeout(function() { el.style.display = 'none'; }, 5000);
        }

        function showMsg(el, text, type) {
            el.textContent = text;
            el.className = 'sub-form-msg ' + (type === 'error' ? 'msg-error' : 'msg-success');
            el.style.display = 'inline';
            setTimeout(function() { el.style.display = 'none'; }, 5000);
        }

        function escapeHtml(str) {
            var div = document.createElement('div');
            div.appendChild(document.createTextNode(str));
            return div.innerHTML;
        }

        function openModal(title, bodyHtml) {
            document.getElementById('modal-title').textContent = title;
            document.getElementById('modal-body').innerHTML = bodyHtml;
            document.getElementById('modal-overlay').style.display = 'flex';
        }

        function closeModal() {
            document.getElementById('modal-overlay').style.display = 'none';
            document.getElementById('modal-body').innerHTML = '';
        }

        document.getElementById('modal-close').addEventListener('click', closeModal);
        document.getElementById('modal-overlay').addEventListener('click', function(e) {
            if (e.target === this) closeModal();
        });

        function loadUsers() {
            fetch('/admin/users/api')
                .then(function(r) { return r.json(); })
                .then(function(res) {
                    if (!res.success) { showNotice(res.error || i18n.loadFailed, 'error'); return; }
                    var tbody = document.getElementById('user-table-body');
                    tbody.innerHTML = '';
                    res.users.forEach(function(u) {
                        var isDefaultAdmin = u.username === 'admin';
                        var keyStatus = u.has_reset_key
                            ? '<span class="key-badge key-configured">' + i18n.keyConfigured + '</span>'
                            : '<span class="key-badge key-not-configured">' + i18n.keyNotConfigured + '</span>';

                        var tr = document.createElement('tr');
                        tr.className = 'user-row';
                        tr.setAttribute('data-id', u.id);
                        tr.setAttribute('data-name', u.username);
                        tr.setAttribute('data-has-key', u.has_reset_key ? '1' : '0');
                        tr.innerHTML =
                            '<td>' + u.id + '</td>' +
                            '<td>' + escapeHtml(u.username) + (isDefaultAdmin ? ' <span class="default-badge">' + i18n.defaultBadge + '</span>' : '') + '</td>' +
                            '<td>' + keyStatus + '</td>' +
                            '<td class="action-cell">' +
                                '<button type="button" class="btn-link btn-password" data-id="' + u.id + '" data-name="' + escapeHtml(u.username) + '">' + i18n.changePassword + '</button>' +
                                (u.has_reset_key
                                    ? '<button type="button" class="btn-link btn-clear-key" data-id="' + u.id + '" data-name="' + escapeHtml(u.username) + '">' + i18n.clearKey + '</button>'
                                    : '<button type="button" class="btn-link btn-keygen" data-id="' + u.id + '" data-name="' + escapeHtml(u.username) + '">' + i18n.generateKey + '</button>'
                                ) +
                                (isDefaultAdmin ? '' : '<button type="button" class="btn-link btn-delete-user" data-id="' + u.id + '" data-name="' + escapeHtml(u.username) + '">' + i18n.deleteBtn + '</button>') +
                            '</td>';
                        tbody.appendChild(tr);
                    });
                })
                .catch(function() { showNotice(i18n.requestFailed, 'error'); });
        }

        document.getElementById('user-table-body').addEventListener('click', function(e) {
            var pwBtn = e.target.closest('.btn-password');
            if (pwBtn) {
                var userId = pwBtn.getAttribute('data-id');
                var userName = pwBtn.getAttribute('data-name');
                openModal(i18n.changePasswordTitle + ' — ' + userName,
                    '<form id="modal-password-form" data-user-id="' + userId + '">' +
                        '<div class="modal-field">' +
                            '<label>' + i18n.oldPassword + '</label>' +
                            '<input type="password" name="oldPassword" autocomplete="current-password" required>' +
                        '</div>' +
                        '<div class="modal-field">' +
                            '<label>' + i18n.newPassword + '</label>' +
                            '<input type="password" name="newPassword" autocomplete="new-password" required>' +
                        '</div>' +
                        '<div class="modal-field">' +
                            '<label>' + i18n.confirmPassword + '</label>' +
                            '<input type="password" name="confirmPassword" autocomplete="new-password" required>' +
                        '</div>' +
                        '<div class="modal-actions">' +
                            '<button type="submit" class="btn-primary">' + i18n.confirmChange + '</button>' +
                            '<button type="button" class="btn-link modal-cancel-btn">' + i18n.cancel + '</button>' +
                            '<span class="sub-form-msg" id="modal-pw-msg"></span>' +
                        '</div>' +
                    '</form>'
                );
                return;
            }

            var kgBtn = e.target.closest('.btn-keygen');
            if (kgBtn) {
                var kgUserId = kgBtn.getAttribute('data-id');
                var kgUserName = kgBtn.getAttribute('data-name');
                openModal(i18n.generateKeyTitle + ' — ' + kgUserName,
                    '<p class="field-hint" style="margin-bottom:12px;">' + i18n.keyGenHint + '</p>' +
                    '<form id="modal-keygen-form" data-user-id="' + kgUserId + '">' +
                        '<div class="modal-field">' +
                            '<label>' + i18n.keyLabel + '</label>' +
                            '<input type="password" name="keyPlaintext" autocomplete="new-password" required>' +
                        '</div>' +
                        '<div class="modal-field">' +
                            '<label>' + i18n.confirmKey + '</label>' +
                            '<input type="password" name="keyConfirm1" autocomplete="new-password" required>' +
                        '</div>' +
                        '<div class="modal-field">' +
                            '<label>' + i18n.confirmKeyAgain + '</label>' +
                            '<input type="password" name="keyConfirm2" autocomplete="new-password" required>' +
                        '</div>' +
                        '<div class="modal-actions">' +
                            '<button type="submit" class="btn-primary">' + i18n.generateKeyBtn + '</button>' +
                            '<button type="button" class="btn-link modal-cancel-btn">' + i18n.cancel + '</button>' +
                            '<span class="sub-form-msg" id="modal-kg-msg"></span>' +
                        '</div>' +
                    '</form>'
                );
                return;
            }

            var ckBtn = e.target.closest('.btn-clear-key');
            if (ckBtn) {
                var ckUserId = ckBtn.getAttribute('data-id');
                var ckUserName = ckBtn.getAttribute('data-name');
                if (confirm(i18n.clearKeyConfirm.replace('{{name}}', ckUserName))) {
                    fetch('/admin/users/' + ckUserId + '/clear-key', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ _csrf: getCsrfToken() })
                    })
                    .then(function(r) { return r.json(); })
                    .then(function(res) {
                        if (res.success) {
                            showNotice(i18n.keyCleared, 'success');
                            loadUsers();
                        } else {
                            showNotice(res.error || i18n.clearFailed, 'error');
                        }
                    })
                    .catch(function() { showNotice(i18n.requestFailed, 'error'); });
                }
                return;
            }

            var delBtn = e.target.closest('.btn-delete-user');
            if (delBtn) {
                var uid = delBtn.getAttribute('data-id');
                var uname = delBtn.getAttribute('data-name');
                if (confirm(i18n.deleteUserConfirm.replace('{{name}}', uname))) {
                    fetch('/admin/users/' + uid, {
                        method: 'DELETE',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ _csrf: getCsrfToken() })
                    })
                    .then(function(r) { return r.json(); })
                    .then(function(res) {
                        if (res.success) {
                            showNotice(i18n.userDeleted, 'success');
                            loadUsers();
                        } else {
                            showNotice(res.error || i18n.deleteFailed, 'error');
                        }
                    })
                    .catch(function() { showNotice(i18n.requestFailed, 'error'); });
                }
            }
        });

        document.getElementById('add-user-btn').addEventListener('click', function() {
            openModal(i18n.addNewUser,
                '<form id="modal-add-user-form">' +
                    '<div class="modal-field">' +
                        '<label>' + i18n.usernameLabel + '</label>' +
                        '<input type="text" name="username" autocomplete="off" required>' +
                    '</div>' +
                    '<div class="modal-field">' +
                        '<label>' + i18n.passwordLabel + '</label>' +
                        '<input type="password" name="password" autocomplete="new-password" required>' +
                    '</div>' +
                    '<div class="modal-field">' +
                        '<label>' + i18n.confirmPasswordLabel + '</label>' +
                        '<input type="password" name="confirmPassword" autocomplete="new-password" required>' +
                    '</div>' +
                    '<div class="modal-actions">' +
                        '<button type="submit" class="btn-primary">' + i18n.createUser + '</button>' +
                        '<button type="button" class="btn-link modal-cancel-btn">' + i18n.cancel + '</button>' +
                        '<span class="sub-form-msg" id="modal-add-msg"></span>' +
                    '</div>' +
                '</form>'
            );
        });

        document.getElementById('modal-body').addEventListener('click', function(e) {
            if (e.target.closest('.modal-cancel-btn')) {
                closeModal();
            }
        });

        document.getElementById('modal-body').addEventListener('submit', function(e) {
            var form = e.target;
            e.preventDefault();

            if (form.id === 'modal-password-form') {
                var userId = form.getAttribute('data-user-id');
                var msg = document.getElementById('modal-pw-msg');
                var data = {
                    oldPassword: form.oldPassword.value,
                    newPassword: form.newPassword.value,
                    confirmPassword: form.confirmPassword.value,
                    _csrf: getCsrfToken()
                };
                if (data.newPassword !== data.confirmPassword) {
                    showMsg(msg, i18n.passwordMismatch, 'error');
                    return;
                }
                fetch('/admin/users/' + userId + '/password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                })
                .then(function(r) { return r.json(); })
                .then(function(res) {
                    if (res.success) {
                        showMsg(msg, res.message || i18n.passwordChangeSuccess, 'success');
                        setTimeout(closeModal, 1500);
                    } else {
                        showMsg(msg, res.error || i18n.changeFailed, 'error');
                    }
                })
                .catch(function() { showMsg(msg, i18n.requestFailed, 'error'); });
                return;
            }

            if (form.id === 'modal-keygen-form') {
                var keyUserId = form.getAttribute('data-user-id');
                var keyMsg = document.getElementById('modal-kg-msg');
                var keyVal = form.keyPlaintext.value;
                var keyC1 = form.keyConfirm1.value;
                var keyC2 = form.keyConfirm2.value;
                if (keyVal !== keyC1 || keyVal !== keyC2) {
                    showMsg(keyMsg, i18n.keyMismatch, 'error');
                    return;
                }
                if (!confirm(i18n.keyGenConfirm)) {
                    return;
                }
                var keyData = {
                    keyPlaintext: keyVal,
                    keyConfirm1: keyC1,
                    keyConfirm2: keyC2,
                    _csrf: getCsrfToken()
                };
                fetch('/admin/users/' + keyUserId + '/generate-key', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(keyData)
                })
                .then(function(r) { return r.json(); })
                .then(function(res) {
                    if (res.success) {
                        var row = document.querySelector('.user-row[data-id="' + keyUserId + '"]');
                        if (row) {
                            var keyCell = row.querySelectorAll('td')[2];
                            keyCell.innerHTML = '<span class="key-badge key-configured">' + i18n.keyConfigured + '</span>';
                            var kgBtnInRow = row.querySelector('.btn-keygen');
                            if (kgBtnInRow) kgBtnInRow.setAttribute('data-has-key', '1');
                        }
                        var maskedKey = keyVal.charAt(0) + '****' + keyVal.charAt(keyVal.length - 1);
                        document.getElementById('modal-body').innerHTML =
                            '<p class="field-hint" style="margin-bottom:12px;">' + i18n.keyRevealHint + '</p>' +
                            '<div class="key-reveal-box">' +
                                '<label>' + i18n.keyLabel + '</label>' +
                                '<div class="key-reveal-row">' +
                                    '<span class="key-masked" id="key-masked">' + escapeHtml(maskedKey) + '</span>' +
                                    '<button type="button" class="btn-link" id="key-reveal-btn">' + i18n.showKey + '</button>' +
                                '</div>' +
                                '<span class="key-plaintext" id="key-plaintext" style="display:none;">' + escapeHtml(keyVal) + '</span>' +
                            '</div>' +
                            '<div class="modal-actions">' +
                                '<button type="button" class="btn-primary modal-cancel-btn">' + i18n.confirmAndClose + '</button>' +
                            '</div>';
                        document.getElementById('key-reveal-btn').addEventListener('click', function() {
                            document.getElementById('key-masked').style.display = 'none';
                            document.getElementById('key-plaintext').style.display = 'inline';
                            this.style.display = 'none';
                        });
                    } else {
                        showMsg(keyMsg, res.error || i18n.keyGenFailed, 'error');
                    }
                })
                .catch(function() { showMsg(keyMsg, i18n.requestFailed, 'error'); });
                return;
            }

            if (form.id === 'modal-add-user-form') {
                var addMsg = document.getElementById('modal-add-msg');
                var addData = {
                    username: form.username.value.trim(),
                    password: form.password.value,
                    confirmPassword: form.confirmPassword.value,
                    _csrf: getCsrfToken()
                };
                if (addData.password !== addData.confirmPassword) {
                    showMsg(addMsg, i18n.passwordMismatch, 'error');
                    return;
                }
                fetch('/admin/users', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(addData)
                })
                .then(function(r) { return r.json(); })
                .then(function(res) {
                    if (res.success) {
                        showNotice(i18n.userCreated, 'success');
                        closeModal();
                        loadUsers();
                    } else {
                        showMsg(addMsg, res.error || i18n.createFailed, 'error');
                    }
                })
                .catch(function() { showMsg(addMsg, i18n.requestFailed, 'error'); });
            }
        });

        loadUsers();
    })();
    </script>
</body>
</html>
